{
  "name": "memory-four-layer",
  "version": "1.0.0",
  "displayName": "四层记忆系统",
  "description": "STM/Episodic/Knowledge/Structural 四层记忆架构，基于 LanceDB 本地向量存储",
  "author": "YourName",
  "license": "MIT",
  "main": "dist/index.js",
  "slots": ["memory"],
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "autoCapture": { "type": "boolean", "default": true },
      "autoRecall": { "type": "boolean", "default": true },
      "dbPath": { "type": "string", "default": "~/.openclaw/memory-db" },
      "vectorDimension": { "type": "number", "enum": [384, 1536], "default": 1536 },
      "embedding": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "model": { "type": "string", "default": "text-embedding-3-small" },
          "baseURL": { "type": "string", "default": "https://api.openai.com/v1" },
          "dimensions": { "type": "number", "default": 1536 }
        },
        "required": ["apiKey"],
        "additionalProperties": false
      },
      "collector": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "maxLogChars": { "type": "number", "default": 800 },
          "dedupeWindowMs": { "type": "number", "default": 300000 },
          "minMessageLength": { "type": "number", "default": 5 },
          "minMessageLengthCJK": { "type": "number", "default": 3 },
          "maxEvidencePerAgentEnd": { "type": "number", "default": 10 },
          "compactionSnapshotMessages": { "type": "number", "default": 20 },
          "excludeTools": {
            "type": "array",
            "items": { "type": "string" },
            "default": ["memory_recall", "memory_store", "memory_forget"]
          },
          "redactKeys": {
            "type": "array",
            "items": { "type": "string" },
            "default": ["apiKey", "token", "password", "secret"]
          }
        },
        "additionalProperties": false
      },
      "router": {
        "type": "object",
        "properties": {
          "classifyMode": { "type": "string", "enum": ["rules_only", "rules_then_llm", "llm_only"], "default": "rules_then_llm" },
          "llmModel": { "type": "string", "default": "haiku" },
          "llmMaxTokens": { "type": "number", "default": 200 },
          "stmTTLMs": { "type": "number", "default": 3600000 },
          "minConfidenceForKnowledge": { "type": "number", "default": 0.7 },
          "minConfidenceForStructural": { "type": "number", "default": 0.8 },
          "batchSize": { "type": "number", "default": 5 },
          "batchDelayMs": { "type": "number", "default": 100 }
        },
        "additionalProperties": false
      },
      "store": {
        "type": "object",
        "properties": {
          "tables": {
            "type": "object",
            "properties": {
              "stm": { "type": "object", "properties": { "maxEntries": { "type": "number", "default": 500 } }, "additionalProperties": false },
              "episodic": { "type": "object", "properties": { "maxEntries": { "type": "number", "default": 10000 } }, "additionalProperties": false },
              "knowledge": { "type": "object", "properties": { "maxEntries": { "type": "number", "default": 2000 } }, "additionalProperties": false },
              "entities": { "type": "object", "properties": { "maxEntries": { "type": "number", "default": 1000 } }, "additionalProperties": false },
              "relations": { "type": "object", "properties": { "maxEntries": { "type": "number", "default": 5000 } }, "additionalProperties": false }
            },
            "additionalProperties": false
          },
          "vectorIndexType": { "type": "string", "enum": ["IVF_PQ", "HNSW"], "default": "IVF_PQ" },
          "ftsEnabled": { "type": "boolean", "default": true },
          "ftsLanguage": { "type": "string", "enum": ["english", "chinese", "auto"], "default": "auto" },
          "batchSize": { "type": "number", "default": 100 },
          "vacuumIntervalMs": { "type": "number", "default": 86400000 }
        },
        "additionalProperties": false
      },
      "retriever": {
        "type": "object",
        "properties": {
          "topK": { "type": "number", "default": 10 },
          "minScore": { "type": "number", "default": 0.3 },
          "maxContentLength": { "type": "number", "default": 500 },
          "layerWeights": {
            "type": "object",
            "properties": {
              "stm": { "type": "number", "default": 0.8 },
              "episodic": { "type": "number", "default": 1.0 },
              "knowledge": { "type": "number", "default": 1.2 },
              "structural": { "type": "number", "default": 1.1 }
            },
            "additionalProperties": false
          },
          "fusionWeights": {
            "type": "object",
            "properties": {
              "vector": { "type": "number", "default": 0.4 },
              "bm25": { "type": "number", "default": 0.2 },
              "recency": { "type": "number", "default": 0.2 },
              "importance": { "type": "number", "default": 0.2 }
            },
            "additionalProperties": false
          },
          "rerankEnabled": { "type": "boolean", "default": false },
          "rerankModel": { "type": "string", "default": "cross-encoder/ms-marco-MiniLM-L-6-v2" },
          "rerankTopK": { "type": "number", "default": 20 },
          "rerankBaseURL": { "type": "string", "default": "" },
          "parallelLayers": { "type": "boolean", "default": true },
          "timeoutMs": { "type": "number", "default": 5000 },
          "dedupeThreshold": { "type": "number", "default": 0.9 },
          "recencyHalfLifeMs": { "type": "number", "default": 86400000 }
        },
        "additionalProperties": false
      },
      "rerank": {
        "type": "object",
        "properties": {
          "apiKey": { "type": "string" },
          "baseURL": { "type": "string", "default": "" },
          "model": { "type": "string", "default": "cross-encoder/ms-marco-MiniLM-L-6-v2" }
        },
        "additionalProperties": false
      },
      "compactor": {
        "type": "object",
        "properties": {
          "compaction": {
            "type": "object",
            "properties": {
              "intervalMs": { "type": "number", "default": 3600000 },
              "enableHookTrigger": { "type": "boolean", "default": true },
              "enableThresholdTrigger": { "type": "boolean", "default": true }
            },
            "additionalProperties": false
          },
          "stm": {
            "type": "object",
            "properties": {
              "maxEntries": { "type": "number", "default": 500 },
              "promoteThreshold": { "type": "number", "default": 0.7 },
              "promoteWindowMs": { "type": "number", "default": 300000 }
            },
            "additionalProperties": false
          },
          "episodic": {
            "type": "object",
            "properties": {
              "maxEntries": { "type": "number", "default": 10000 },
              "retentionMs": { "type": "number", "default": 2592000000 },
              "chainAgeThresholdMs": { "type": "number", "default": 86400000 },
              "minChainLengthForCompression": { "type": "number", "default": 3 }
            },
            "additionalProperties": false
          },
          "knowledge": {
            "type": "object",
            "properties": {
              "maxEntries": { "type": "number", "default": 2000 },
              "mergeSimilarityThreshold": { "type": "number", "default": 0.92 }
            },
            "additionalProperties": false
          },
          "memoryMd": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "maxEntries": { "type": "number", "default": 150 },
              "maxTokens": { "type": "number", "default": 10000 },
              "path": { "type": "string", "default": "MEMORY.md" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "required": ["embedding"],
    "additionalProperties": false
  },
  "uiHints": {
    "embedding.apiKey": { 
      "label": "Embedding API Key", 
      "sensitive": true,
      "placeholder": "sk-...",
      "description": "OpenAI API Key 用于向量嵌入"
    },
    "embedding.model": {
      "label": "嵌入模型",
      "description": "向量嵌入模型名称",
      "advanced": true
    },
    "embedding.baseURL": {
      "label": "API Base URL",
      "description": "自定义 API 端点（可选）",
      "advanced": true
    },
    "dbPath": { 
      "label": "数据库路径", 
      "description": "LanceDB 本地存储路径，支持 ~ 扩展"
    },
    "autoCapture": {
      "label": "自动采集",
      "description": "是否自动采集 Hook 事件到记忆系统"
    },
    "autoRecall": {
      "label": "自动召回",
      "description": "是否在 Agent 启动前自动注入相关记忆"
    },
    "collector.maxLogChars": {
      "label": "最大日志字符数",
      "description": "工具调用日志截断长度",
      "advanced": true
    },
    "collector.dedupeWindowMs": {
      "label": "去重窗口（毫秒）",
      "description": "事件去重时间窗口",
      "advanced": true
    },
    "compactor.compaction.intervalMs": {
      "label": "压缩间隔（毫秒）",
      "description": "定时压缩任务的触发间隔"
    },
    "retriever.topK": {
      "label": "检索数量",
      "description": "默认返回的记忆条目数"
    },
    "retriever.minScore": {
      "label": "最低分数阈值",
      "description": "记忆检索的最低相似度分数（0-1）"
    },
    "retriever.rerankEnabled": {
      "label": "启用 Re-ranker",
      "description": "开启后使用交叉编码器重排序检索结果，需配合 rerank 配置块提供 API Key",
      "advanced": true
    },
    "rerank.apiKey": {
      "label": "Re-ranker API Key",
      "sensitive": true,
      "placeholder": "sk-...",
      "description": "Re-ranker 服务的 API Key（Cohere / Jina 等）"
    },
    "rerank.baseURL": {
      "label": "Re-ranker Base URL",
      "description": "Re-ranker 服务端点（可选，自定义部署时填写）",
      "advanced": true
    }
  }
}
